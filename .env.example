# =============================================================================
# LAND INTELLIGENCE SYSTEM - ENVIRONMENT CONFIGURATION
# =============================================================================
# Copy this file to .env and fill in your actual values
# NEVER commit .env file to version control
# =============================================================================

# -----------------------------------------------------------------------------
# APPLICATION SETTINGS
# -----------------------------------------------------------------------------
APP_NAME="Land Intelligence & Stewardship System"
APP_VERSION="1.0.0"
ENVIRONMENT="development"  # Options: development, staging, production
DEBUG=True
LOG_LEVEL="INFO"  # Options: DEBUG, INFO, WARNING, ERROR, CRITICAL

# -----------------------------------------------------------------------------
# SERVER CONFIGURATION (Desktop Single-Machine)
# -----------------------------------------------------------------------------
HOST="127.0.0.1"
PORT=8000
WORKERS=1  # Single-machine: Keep at 1
RELOAD=True  # Set to False in production

# -----------------------------------------------------------------------------
# DATABASE CONFIGURATION (MySQL 8.0+)
# -----------------------------------------------------------------------------
DATABASE_HOST="localhost"
DATABASE_PORT=3306
DATABASE_NAME="land_intelligence_db"
DATABASE_USER="land_admin"
DATABASE_PASSWORD="your_secure_password_here"
DATABASE_ECHO=False  # Set to True for SQL query debugging

# Database Connection Pool Settings
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=3600

# -----------------------------------------------------------------------------
# SECURITY & AUTHENTICATION
# -----------------------------------------------------------------------------
# Generate secret key: openssl rand -hex 32
SECRET_KEY="your_secret_key_here_generate_with_openssl_rand_hex_32"
ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# Password Hashing
BCRYPT_ROUNDS=12

# -----------------------------------------------------------------------------
# FILE STORAGE PATHS (Desktop Application)
# -----------------------------------------------------------------------------
# Windows Example:
# STORAGE_ROOT="C:/LandIntelligence"
# DOCUMENTS_PATH="C:/LandIntelligence/documents"
# BACKUPS_LOCAL_PATH="C:/LandIntelligence/backups"
# LOGS_PATH="C:/LandIntelligence/logs"
# TEMP_PATH="C:/LandIntelligence/temp"

# Linux Example:
STORAGE_ROOT="/home/user/LandIntelligence"
DOCUMENTS_PATH="/home/user/LandIntelligence/documents"
BACKUPS_LOCAL_PATH="/home/user/LandIntelligence/backups"
LOGS_PATH="/home/user/LandIntelligence/logs"
TEMP_PATH="/home/user/LandIntelligence/temp"

# -----------------------------------------------------------------------------
# GIS CONFIGURATION
# -----------------------------------------------------------------------------
# Coordinate Reference System
DEFAULT_SRID=4326  # WGS 84 (GPS coordinates)

# Master Plan Data
MASTER_PLAN_PATH="/home/user/LandIntelligence/gis-data/master-plans/national-land-use-masterplan-2024.gpkg"

# -----------------------------------------------------------------------------
# BACKUP CONFIGURATION
# -----------------------------------------------------------------------------
# Backup Schedule (cron expressions)
BACKUP_DAILY_CRON="0 3 * * *"      # Daily at 3:00 AM
BACKUP_WEEKLY_CRON="0 2 * * 0"     # Weekly on Sunday at 2:00 AM
BACKUP_MONTHLY_CRON="0 2 1 * *"    # Monthly on 1st at 2:00 AM

# Retention Policies (days)
BACKUP_LOCAL_RETENTION_DAYS=7
BACKUP_CLOUD_RETENTION_DAYS=90
BACKUP_ARCHIVE_RETENTION_DAYS=2555  # ~7 years

# Backup Compression
BACKUP_COMPRESSION="gzip"  # Options: gzip, bz2, xz, zstd

# -----------------------------------------------------------------------------
# CLOUD STORAGE - GOOGLE CLOUD STORAGE
# -----------------------------------------------------------------------------
GCS_ENABLED=True
GCS_PROJECT_ID="church-land-intelligence"
GCS_BUCKET_NAME="land-intelligence-backups"
GCS_CREDENTIALS_PATH="/path/to/service-account-key.json"
GCS_REGION="us-central1"

# Client-Side Encryption (optional)
GCS_ENCRYPTION_ENABLED=False
GCS_ENCRYPTION_KEY_PATH="/secure/encryption.key"

# -----------------------------------------------------------------------------
# CLOUD STORAGE - BACKBLAZE B2 (Optional Alternative)
# -----------------------------------------------------------------------------
B2_ENABLED=False
B2_ACCOUNT_ID="your_backblaze_account_id"
B2_APPLICATION_KEY="your_backblaze_application_key"
B2_BUCKET_NAME="church-land-backups"

# -----------------------------------------------------------------------------
# EMAIL NOTIFICATIONS
# -----------------------------------------------------------------------------
EMAIL_ENABLED=True
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USE_TLS=True
SMTP_USERNAME="backup-system@church.org"
SMTP_PASSWORD="your_email_password_or_app_password"

# Notification Recipients (comma-separated)
EMAIL_RECIPIENTS="it-admin@church.org,land-officer@church.org"

# Email Templates
EMAIL_FROM="Land Intelligence System <backup-system@church.org>"
EMAIL_REPLY_TO="it-support@church.org"

# -----------------------------------------------------------------------------
# CELERY CONFIGURATION (Background Tasks - Optional)
# -----------------------------------------------------------------------------
CELERY_ENABLED=False
CELERY_BROKER_URL="redis://localhost:6379/0"
CELERY_RESULT_BACKEND="redis://localhost:6379/0"
CELERY_TASK_SERIALIZER="json"
CELERY_RESULT_SERIALIZER="json"
CELERY_ACCEPT_CONTENT=["json"]
CELERY_TIMEZONE="Africa/Kigali"

# -----------------------------------------------------------------------------
# QR CODE GENERATION
# -----------------------------------------------------------------------------
QR_CODE_VERSION=1  # QR code size (1-40)
QR_CODE_ERROR_CORRECTION="H"  # Options: L, M, Q, H (H = highest)
QR_CODE_BOX_SIZE=10  # Pixel size of each QR code box
QR_CODE_BORDER=4  # Border size in boxes

# QR Code Storage
QR_CODE_PATH="/home/user/LandIntelligence/qr-codes/generated"

# -----------------------------------------------------------------------------
# TAX CALCULATION
# -----------------------------------------------------------------------------
# Default tax rates (can be overridden in database)
DEFAULT_TAX_RATE_PER_SQM=0.50  # Currency per square meter
PENALTY_RATE_PER_DAY=0.001  # 0.1% per day
TAX_YEAR_START_MONTH=1  # January

# -----------------------------------------------------------------------------
# API RATE LIMITING (Optional)
# -----------------------------------------------------------------------------
RATE_LIMIT_ENABLED=False
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_PER_HOUR=1000

# -----------------------------------------------------------------------------
# CORS SETTINGS (Desktop App - Restricted)
# -----------------------------------------------------------------------------
CORS_ORIGINS=["http://localhost:8080"]  # JavaFX app if using web view
CORS_ALLOW_CREDENTIALS=True
CORS_ALLOW_METHODS=["GET", "POST", "PUT", "DELETE", "PATCH"]
CORS_ALLOW_HEADERS=["*"]

# -----------------------------------------------------------------------------
# LOGGING CONFIGURATION
# -----------------------------------------------------------------------------
LOG_TO_FILE=True
LOG_FILE_PATH="/home/user/LandIntelligence/logs/application.log"
LOG_FILE_MAX_BYTES=10485760  # 10MB
LOG_FILE_BACKUP_COUNT=5
LOG_FORMAT="%(asctime)s - %(name)s - %(levelname)s - %(message)s"

# Backup-specific logging
BACKUP_LOG_PATH="/home/user/LandIntelligence/logs/backup.log"
VERIFICATION_LOG_PATH="/home/user/LandIntelligence/logs/verification.log"
RESTORE_LOG_PATH="/home/user/LandIntelligence/logs/restore.log"

# -----------------------------------------------------------------------------
# PERFORMANCE & OPTIMIZATION
# -----------------------------------------------------------------------------
# File Upload Limits
MAX_UPLOAD_SIZE_MB=50
ALLOWED_DOCUMENT_TYPES="pdf,jpg,jpeg,png,doc,docx,xls,xlsx"

# GIS Processing
GIS_PROCESSING_TIMEOUT=300  # 5 minutes
SPATIAL_INDEX_BUFFER_SIZE=1000

# Database Query Timeout
QUERY_TIMEOUT_SECONDS=30

# -----------------------------------------------------------------------------
# MAINTENANCE & MONITORING
# -----------------------------------------------------------------------------
# Automated Tasks
ORPHAN_FILE_DETECTION_ENABLED=True
ORPHAN_FILE_CHECK_CRON="0 4 * * *"  # Daily at 4:00 AM

# Health Check
HEALTH_CHECK_ENABLED=True
HEALTH_CHECK_INTERVAL_SECONDS=60

# -----------------------------------------------------------------------------
# DEVELOPMENT & TESTING (Development Only)
# -----------------------------------------------------------------------------
# Set to False in production
SEED_DATABASE=False
CREATE_TEST_DATA=False
ENABLE_API_DOCS=True  # Swagger UI at /docs
ENABLE_REDOC=True  # ReDoc at /redoc

# -----------------------------------------------------------------------------
# TIMEZONE & LOCALIZATION
# -----------------------------------------------------------------------------
TIMEZONE="Africa/Kigali"
LOCALE="en_RW"
CURRENCY="RWF"  # Rwandan Franc

# -----------------------------------------------------------------------------
# AUDIT & COMPLIANCE
# -----------------------------------------------------------------------------
AUDIT_LOG_ENABLED=True
AUDIT_LOG_RETENTION_DAYS=2555  # 7 years
AUDIT_SENSITIVE_OPERATIONS=True

# -----------------------------------------------------------------------------
# DISASTER RECOVERY
# -----------------------------------------------------------------------------
DR_PLAN_ENABLED=True
DR_TEST_SCHEDULE_CRON="0 2 1 */3 *"  # Quarterly on 1st at 2:00 AM
DR_NOTIFICATION_EMAIL="disaster-recovery@church.org"

# =============================================================================
# END OF CONFIGURATION
# =============================================================================
